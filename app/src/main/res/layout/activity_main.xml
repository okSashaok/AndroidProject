<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/top_avatar"
        android:layout_width="128dp"
        android:layout_height="128dp"
        tools:src="@drawable/ic_launcher_foreground"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="-32dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-32dp"
        android:contentDescription="@string/description_avatar"/>

    <TextView
        android:id="@+id/top_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        tools:text="@string/top_text"
        app:layout_constraintTop_toTopOf="@id/top_avatar"
        app:layout_constraintBottom_toTopOf="@id/top_datePublication"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/top_avatar"
        app:layout_constraintEnd_toStartOf="@id/top_more"
        android:layout_marginStart="-16dp"/>

    <TextView
        android:id="@+id/top_datePublication"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="@string/top_datePublication"
        app:layout_constraintStart_toStartOf="@id/top_text"
        app:layout_constraintTop_toBottomOf="@id/top_text"
        app:layout_constraintBottom_toBottomOf="@id/top_avatar"
        app:layout_constraintStart_toEndOf="@id/top_avatar"/>

    <ImageButton
        android:id="@+id/top_more"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="#0000"
        app:tint="#888"
        tools:src="@drawable/baseline_more_vert_24"
        app:layout_constraintTop_toTopOf="@id/top_text"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="0dp"
        android:contentDescription="@string/description_baseline_more_vert_24"/>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/top_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="top_avatar, top_datePublication, top_text"
        app:barrierDirection="bottom"
        app:barrierMargin="-16dp"/>

    <TextView
        android:id="@+id/main_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoLink="web"
        tools:text="@string/main_text"
        app:layout_constraintTop_toBottomOf="@id/top_barrier"/>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="main_text"
        app:barrierDirection="bottom"
        app:barrierMargin="16dp"/>

    <ImageView
        android:id="@+id/bottom_imageFavorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="#888"
        app:layout_constraintTop_toTopOf="@id/bottom_barrier"
        tools:src="@drawable/favorite_24"
        android:contentDescription="@string/description_avatar"/>

    <TextView
        android:id="@+id/bottom_textFavorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="@string/bottom_textFavorite"
        app:layout_constraintTop_toTopOf="@id/bottom_imageFavorite"
        app:layout_constraintStart_toEndOf="@id/bottom_imageFavorite"
        android:layout_marginStart="4dp"/>

    <ImageView
        android:id="@+id/bottom_imageShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="#888"
        app:layout_constraintTop_toTopOf="@id/bottom_textFavorite"
        app:layout_constraintStart_toEndOf="@id/bottom_textFavorite"
        tools:src="@drawable/share_24"
        android:layout_marginStart="8dp"
        android:contentDescription="@string/description_avatar"/>

    <TextView
        android:id="@+id/bottom_textShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="@string/bottom_textShare"
        app:layout_constraintTop_toTopOf="@id/bottom_imageShare"
        app:layout_constraintStart_toEndOf="@id/bottom_imageShare"
        android:layout_marginStart="4dp"/>

    <ImageView
        android:id="@+id/bottom_imageVisibility"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:tint="#888"
        app:layout_constraintTop_toTopOf="@id/bottom_textShare"
        app:layout_constraintEnd_toStartOf="@id/bottom_textVisibility"
        tools:src="@drawable/visibility_24"
        android:layout_marginEnd="4dp"
        android:contentDescription="@string/description_avatar"/>

    <TextView
        android:id="@+id/bottom_textVisibility"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="@string/bottom_textVisibility"
        app:layout_constraintTop_toTopOf="@id/bottom_imageVisibility"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>